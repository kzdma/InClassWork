<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="InClassWork.Views.SignUpView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    NavigationPage.HasNavigationBar="False">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0.0" Color="#004FF9" />
            <GradientStop Offset="1.0" Color="#FFF94C" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ContentPage.Resources>
        <Style x:Key="InvalidEntryStyle" TargetType="Entry">
            <Setter Property="TextColor" Value="Red" />
        </Style>
        <Style x:Key="ValidEntryStyle" TargetType="Entry">
            <Setter Property="TextColor" Value="Wheat" />
        </Style>
    </ContentPage.Resources>


    <Grid ColumnDefinitions="*,8*,*" RowDefinitions="*,4*,*">

        <!--  כותרת  -->
        <HorizontalStackLayout
            Grid.Column="1"
            HorizontalOptions="Center"
            VerticalOptions="Center">

            <Label
                FontSize="24"
                Text="Create Account"
                TextColor="White" />

        </HorizontalStackLayout>

        <VerticalStackLayout Grid.Row="1" Grid.Column="1">

            <!--  שדה שם פרטי  -->
            <Border
                Margin="0,0,0,10"
                Padding="10"
                HeightRequest="50"
                Stroke="#ccc"
                StrokeShape="RoundRectangle 8"
                StrokeThickness="1">

                <Entry
                    FontSize="18"
                    HeightRequest="18"
                    Placeholder="First Name"
                    Text="{Binding FirstName}"
                    TextColor="Wheat" />

            </Border>

            <!--  שדה שם משפחה  -->
            <Border
                Margin="0,0,0,10"
                Padding="10"
                HeightRequest="50"
                Stroke="#ccc"
                StrokeShape="RoundRectangle 8"
                StrokeThickness="1">

                <Entry
                    FontSize="18"
                    HeightRequest="18"
                    Placeholder="Last Name"
                    Text="{Binding LastName}"
                    TextColor="Wheat" />

            </Border>

            <!--  שדה דואל  -->
            <Border
                Margin="0,0,0,10"
                Padding="10"
                HeightRequest="50"
                Stroke="#ccc"
                StrokeShape="RoundRectangle 8"
                StrokeThickness="1">

                <Entry
                    FontSize="18"
                    HeightRequest="18"
                    Keyboard="Email"
                    Placeholder="Email"
                    Text="{Binding UserEmail}">

                    <Entry.Behaviors>
                        <toolkit:EmailValidationBehavior
                            Flags="ValidateOnValueChanged"
                            InvalidStyle="{StaticResource InvalidEntryStyle}"
                            ValidStyle="{StaticResource ValidEntryStyle}" />
                    </Entry.Behaviors>
                </Entry>

            </Border>

            <!--  שדה סיסמה  -->
            <Border
                Margin="0,0,0,10"
                HeightRequest="50"
                Stroke="#ccc"
                StrokeShape="RoundRectangle 8"
                StrokeThickness="1">
                <Grid
                    Padding="10"
                    ColumnDefinitions="*,Auto"
                    VerticalOptions="Center">

                    <Entry
                        BackgroundColor="Transparent"
                        FontSize="18"
                        HeightRequest="18"
                        IsPassword="{Binding IsPasswordNotVisible}"
                        Placeholder="Password"
                        Text="{Binding UserPassword}"
                        TextColor="Wheat"
                        VerticalOptions="Center" />

                    <Button
                        Margin="5,0,0,0"
                        Padding="0"
                        BackgroundColor="Transparent"
                        Command="{Binding TogglePasswordCommand}"
                        FontFamily="MaterialIcons"
                        FontSize="24"
                        HorizontalOptions="End"
                        Text="{Binding PasswordButtonText}"
                        TextColor="White"
                        VerticalOptions="Center" />
                </Grid>
            </Border>

            <!--  שדה מספר נייד  -->
            <Border
                Margin="0,0,0,10"
                Padding="10"
                HeightRequest="50"
                Stroke="#ccc"
                StrokeShape="RoundRectangle 8"
                StrokeThickness="1">

                <Entry
                    FontSize="18"
                    HeightRequest="18"
                    Keyboard="Telephone"
                    Placeholder="Mobile"
                    Text="{Binding UserMobile}"
                    TextColor="Wheat" />

            </Border>

            <!--  כפתור כניסה  -->
            <Button
                Command="{Binding SignUpCommand}"
                CornerRadius="8"
                FontSize="20"
                HeightRequest="60"
                Text="Sign Up"
                TextColor="White" />

            <!--  Already have an account?  -->
            <HorizontalStackLayout
                Margin="0,5,0,0"
                HorizontalOptions="Center"
                VerticalOptions="Center">
                <Label
                    Margin="14,0,0,0"
                    FontSize="16"
                    Text="Already have an account?"
                    TextColor="White"
                    VerticalTextAlignment="Center" />
                <Button
                    BackgroundColor="Transparent"
                    FontSize="16"
                    Text="SignIn"
                    TextColor="BlueViolet" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </Grid>
</ContentPage>